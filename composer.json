{
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
    "require": {
        "slim/slim": "^4.15",
        "slim/psr7": "^1.8",
        "slim/http": "^1.4",
        "slim/php-view": "^3.4",
        "php-di/php-di": "^7.1",
        "slim/flash": "^0.4.0",
        "ext-pdo": "*",
      "ext-mbstring": "*"
    },
  "require-dev": {
    "squizlabs/php_codesniffer": "^4.0",
    "phpunit/phpunit": "^11.5",
    "roave/security-advisories": "dev-latest",
    "phpstan/phpstan": "^2.1",
    "phpstan/extension-installer": "^1.4",
    "phpstan/phpstan-phpunit": "^2.0"
  },
  "config": {
    "allow-plugins": {
      "phpstan/extension-installer": true
    }
  }
}
